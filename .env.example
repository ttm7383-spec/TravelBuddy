# TravelBuddy Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# MOCK DATA MODE (set to "true" for demo)
# When true, all API calls return mock data
# so the app works without real API keys.
# Set to "false" to use real APIs below.
# ===========================================
USE_MOCK_DATA=true

# ===========================================
# Firebase Configuration
# Get these from Firebase Console → Project Settings
# ===========================================
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (for backend)
# Path to your Firebase service account JSON key file
FIREBASE_SERVICE_ACCOUNT_KEY=path/to/serviceAccountKey.json

# ===========================================
# Amadeus API (real-time flights + hotels)
# Sign up: https://developers.amadeus.com
# 1. Create free account
# 2. Create new app → get Client ID and Secret
# 3. Free tier: 2000 flight searches/month
# 4. Test environment works immediately
# When USE_MOCK_DATA=true, these are not needed
# ===========================================
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret

# ===========================================
# OpenWeatherMap API (weather forecasts)
# Sign up: https://openweathermap.org/api
# ===========================================
OPENWEATHER_API_KEY=your_openweather_api_key

# ===========================================
# Foursquare Places API (attractions)
# Sign up: https://developer.foursquare.com
# ===========================================
FOURSQUARE_API_KEY=your_foursquare_api_key

# ===========================================
# Flask Configuration
# ===========================================
FLASK_SECRET_KEY=change_this_to_a_random_string
FLASK_DEBUG=true
FLASK_PORT=5000
